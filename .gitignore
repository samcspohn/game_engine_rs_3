# =============================================================================
# Rust
# =============================================================================

# Cargo build artifacts
/target/
**/target/

# Cargo lock file — keep for binaries/apps, remove for libraries.
# This is a workspace with binary crates (editor, packager, test-game),
# so Cargo.lock is intentionally tracked and NOT listed here.

# Backup files generated by rustfmt
**/*.rs.bk

# =============================================================================
# Compiled Shaders (SPIR-V)
# =============================================================================
**/*.spv
**/*.spv.dis

# =============================================================================
# Editor / IDE
# =============================================================================

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (RustRover, CLion, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

