#version 450

// GPU frustum cull + compaction + MVP build (Design B — the GPU-driven draw
// pass). One invocation per **transform slot** (the dispatch covers the whole
// renderer capacity); there is no CPU-sorted topology. For each slot `i`:
//   1. read `mesh_id = GPURenderers[i]`; skip if it has no renderer;
//   2. `slot = redirect[mesh_id]` (placeholder while loading, real once
//      resolved, error on failure);
//   3. compose the model matrix from `SoT[i]` (transform id == slot index),
//      transform the mesh's bounding sphere (from `mesh_table[slot]`) into
//      world space, and frustum-test it against `view_proj`;
//   4. if visible, atomically claim the next slot in that drawable slot's
//      contiguous MVP region (`base = indirect[slot].first_instance`,
//      `local = atomicAdd(indirect[slot].instance_count, 1)`) and write the
//      compacted MVP there.
// Culled / renderer-less slots write nothing. The indirect `instance_count`s
// were reset to 0 by a `vkCmdCopyBuffer(template → args)` recorded just before
// this dispatch, so the atomics accumulate visible counts from zero.
//
// Descriptor sets:
// * Set 0 — SoT pos/rot/scale (world), the `GPURenderers` buffer, the redirect
//   map, the mesh table (bounds), the output MVP buffer, and the per-slot
//   indirect commands (read `first_instance`, atomic-add `instance_count`).
// * Set 1 — the single-mat4 `view_proj` SoT buffer.
//
// NOTE (perf): compaction uses one global `atomicAdd` per visible instance on
// the slot's counter. A workgroup-local aggregation (keyed on dynamic
// per-workgroup slot equality) is the planned follow-up.

layout(local_size_x = 64) in;

layout(push_constant) uniform PC {
    uint renderer_capacity; // dispatch range == GPURenderers / SoT length
} pc;

struct MeshEntry {
    uint index_count;
    uint first_index;
    int vertex_offset;
    uint pad0;
    vec3 bounds_center;
    float bounds_radius;
};

layout(set = 0, binding = 0) readonly buffer Pos {
    vec4 p[];
} u_pos;
layout(set = 0, binding = 1) readonly buffer Rot {
    vec4 q[];
} u_rot;
layout(set = 0, binding = 2) readonly buffer Scl {
    vec4 s[];
} u_scl;
// GPURenderers: one mesh_id per transform slot; 0xFFFFFFFF == no renderer.
layout(set = 0, binding = 3) readonly buffer Renderers {
    uint mesh_id[];
} u_renderers;
// Redirect: mesh_id -> drawable slot.
layout(set = 0, binding = 4) readonly buffer Redirect {
    uint slot[];
} u_redirect;
// Mesh table: per drawable slot, geometry offsets + bounding sphere.
layout(set = 0, binding = 5) readonly buffer MeshTable {
    MeshEntry e[];
} u_table;
layout(set = 0, binding = 6) writeonly buffer Mvp {
    mat4 m[];
} u_mvp;
// Per-slot indirect commands as a flat u32 array (5 u32 per command:
// index_count[0], instance_count[1], first_index[2], vertex_offset[3],
// first_instance[4]).
layout(set = 0, binding = 7) buffer Indirect {
    uint cmd[];
} u_indirect;

layout(set = 1, binding = 0) readonly buffer ViewProj {
    mat4 view_proj;
} u_vp;

const uint NO_RENDERER = 0xFFFFFFFFu;

mat4 trs_to_model(vec3 t, vec4 q, vec3 s) {
    float xx = q.x * q.x, yy = q.y * q.y, zz = q.z * q.z;
    float xy = q.x * q.y, xz = q.x * q.z, yz = q.y * q.z;
    float wx = q.w * q.x, wy = q.w * q.y, wz = q.w * q.z;

    vec3 c0 = vec3(1.0 - 2.0 * (yy + zz), 2.0 * (xy + wz), 2.0 * (xz - wy)) * s.x;
    vec3 c1 = vec3(2.0 * (xy - wz), 1.0 - 2.0 * (xx + zz), 2.0 * (yz + wx)) * s.y;
    vec3 c2 = vec3(2.0 * (xz + wy), 2.0 * (yz - wx), 1.0 - 2.0 * (xx + yy)) * s.z;
    return mat4(
        vec4(c0, 0.0),
        vec4(c1, 0.0),
        vec4(c2, 0.0),
        vec4(t, 1.0)
    );
}

// Gribb–Hartmann plane extraction (column-major clip matrix, Vulkan z in
// [0,1]). Visible iff (plane.xyz·c + plane.w)/|plane.xyz| >= -r for all six.
bool sphere_in_frustum(mat4 m, vec3 c, float r) {
    vec4 r0 = vec4(m[0][0], m[1][0], m[2][0], m[3][0]);
    vec4 r1 = vec4(m[0][1], m[1][1], m[2][1], m[3][1]);
    vec4 r2 = vec4(m[0][2], m[1][2], m[2][2], m[3][2]);
    vec4 r3 = vec4(m[0][3], m[1][3], m[2][3], m[3][3]);

    vec4 planes[6];
    planes[0] = r3 + r0; // left
    planes[1] = r3 - r0; // right
    planes[2] = r3 + r1; // bottom
    planes[3] = r3 - r1; // top
    planes[4] = r2; // near
    planes[5] = r3 - r2; // far

    for (int i = 0; i < 6; ++i) {
        vec4 pl = planes[i];
        float len = length(pl.xyz);
        if (len > 0.0) {
            float dist = (dot(pl.xyz, c) + pl.w) / len;
            if (dist < -r) {
                return false;
            }
        }
    }
    return true;
}

void main() {
    uint i = gl_GlobalInvocationID.x; // transform slot
    if (i >= pc.renderer_capacity) return;

    uint mesh_id = u_renderers.mesh_id[i];
    if (mesh_id == NO_RENDERER) return;
    uint slot = u_redirect.slot[mesh_id];

    vec3 pos = u_pos.p[i].xyz;
    vec4 rot = u_rot.q[i];
    vec3 scl = u_scl.s[i].xyz;
    mat4 model = trs_to_model(pos, rot, scl);

    MeshEntry me = u_table.e[slot];
    vec3 center_world = (model * vec4(me.bounds_center, 1.0)).xyz;
    float max_scale = max(max(abs(scl.x), abs(scl.y)), abs(scl.z));
    float radius_world = me.bounds_radius * max_scale;

    if (!sphere_in_frustum(u_vp.view_proj, center_world, radius_world)) {
        return;
    }

    uint base = u_indirect.cmd[slot * 5u + 4u]; // first_instance
    uint local = atomicAdd(u_indirect.cmd[slot * 5u + 1u], 1u); // instance_count++
    u_mvp.m[base + local] = u_vp.view_proj * model;
}
